{
  "private": true,
  "workspaces": [
    "istampit-web",
    "istampit-action",
    "istampit-cli"
  ],
  "scripts": {
    "vercel-build": "npm --workspace istampit-web run build",
    "lint:upgrade-check": "npm outdated --workspaces || node -e \"process.exit(0)\"",
    "lint:upgrade-eslint": "npm install -D eslint@latest @eslint/config-array @eslint/object-schema && npm --workspace istampit-web install -D eslint@latest",
    "deps:audit-fix": "npm audit fix --workspaces || node -e \"process.exit(0)\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "next": "^16.2.3",
    "postcss": "^8.5.8",
    "postcss-nested": "^7.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "engines": {
    "node": ">=20.19.0 <21"
  },
  "packageManager": "npm@10.9.7"
}
